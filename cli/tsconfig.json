{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@app/*": ["../app/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../app/src/parser/**/*.ts",
    "../app/src/rules/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "../app/src/**/*.test.ts",
    "../app/src/**/*.bench.test.ts",
    "../app/src/parser/testFixtures.ts"
  ]
}
